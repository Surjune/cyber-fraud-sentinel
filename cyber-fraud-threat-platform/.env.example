# Example Environment Variables
# Copy this file to .env and fill in your actual values

# Google Gemini API Key (optional, only needed if using update_threat_index.py)
# Get yours from: https://aistudio.google.com/app/apikeys
AI_API_KEY=your_api_key_here_not_the_real_one

# Gmail Configuration (optional, for email notifications)
# SENDER_EMAIL=your-email@gmail.com
# SENDER_PASSWORD=your-app-password

# Backend Configuration
# BACKEND_HOST=127.0.0.1
# BACKEND_PORT=8004

# Frontend Configuration
# FRONTEND_URL=http://127.0.0.1:5173
